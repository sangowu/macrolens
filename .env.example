# Copy this file to .env and fill in your API keys

# Required: LLM provider (choose one)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: Embedding (ModelScope online inference)
MODELSCOPE_API_KEY=your_modelscope_api_key_here

# Required: Reranker (DashScope)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Required: FRED macroeconomic data
FRED_API_KEY=your_fred_api_key_here

# Optional: SEC EDGAR (unauthenticated works but rate-limited)
# SEC_USER_AGENT=YourName yourname@example.com
